# ================= ฝั่ง SERVER (ลับ! ห้าม commit / ตั้งใน Vercel dashboard) =================
# Service account email จาก Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# Private key จากไฟล์ JSON ของ service account (ใส่ทั้งก้อนในเครื่องหมายคำพูด, \n คงไว้)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Sheet ID จาก URL: https://docs.google.com/spreadsheets/d/[SHEET_ID]/edit
SHEET_ID=

# ================= ฝั่ง CLIENT (Vite จะฝังลงในโค้ดหน้าเว็บ — ห้ามใส่ของลับ) =================
VITE_SHEET_ID=
